# ===========================================
# Abel Begena – Server environment template
# Copy to .env and fill in real values.
# ===========================================

# ----- App -----
NODE_ENV=development
PORT=4001

# ----- Database -----
MONGO_URI=mongodb://localhost:27017/abel-begena

# ----- Auth (JWT) -----
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# ----- CORS & frontend (for cookies and redirects) -----
# Comma-separated list of allowed origins, e.g. http://localhost:3000,https://yourdomain.com
FRONTEND_URI=http://localhost:3000

# ----- Rate limiting -----
THROTTLE_TTL=60
THROTTLE_LIMIT=120

# ----- Email (Gmail SMTP only) -----
# 1. Use a Gmail account. Enable 2FA, then create an "App password": https://myaccount.google.com/apppasswords
# 2. Set the variables below.
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your.gmail@gmail.com
EMAIL_PASS=your-16-char-app-password
EMAIL_FROM=Abel Begena Conservatory <your.gmail@gmail.com>

# ----- File upload (Cloudinary) -----
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ----- Optional: Scheduling & meetings -----
# Cron for auto-marking absent students (default: 7 PM daily)
AUTO_ABSENCE_CRON=0 19 * * *
# Days ahead to consider "payment due soon" for reminders
PAYMENT_DUE_SOON_DAYS=3
# Base URL for meeting provider (if you use one)
MEETING_PROVIDER_BASE_URL=

# ----- Swagger -----
ENABLE_SWAGGER=true
